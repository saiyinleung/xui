{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build xui",
            "osx": {
                "type": "shell",
                "command": "bash",
                "args": ["build.sh"],
            },

            "windows": {
                "type": "process",
                "command": "cmd",
                "args": ["/c", "C:\\Program Files (x86)\\Microsoft Visual Studio\\2019\\Community\\VC\\Auxiliary\\Build\\vcvars64.bat", "&&", "build.bat"],
            },

            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
