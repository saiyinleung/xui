{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build xui",
            "type": "shell",
            "osx": {
                "command": "bash",
                "args": ["build.sh"],
            },

            "windows": {
                "command": "cmd",
                "args": ["/c", "build.bat"],
            },

            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
